<celestial.controls:AdornerDialog
    x:Class="Unsafe_space_travels.Desktop.UI.StartupDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:celestial.components="clr-namespace:Celestial.Components;assembly=Celestial"
    xmlns:celestial.controls="clr-namespace:Celestial.Controls;assembly=Celestial"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Padding="20"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{StaticResource Celestial.Brushes.Background}"
    Closing="startupDialog_Closing"
    Loaded="startupDialog_Loaded"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="titleTextBlock"
            Grid.Row="0"
            HorizontalAlignment="Center"
            FontSize="16"
            FontWeight="Bold"
            Text="Startup" />

        <StackPanel
            Grid.Row="1"
            Margin="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Vertical">
            <TextBlock
                x:Name="oldVersionTextBlock"
                HorizontalAlignment="Center"
                Foreground="LightGray" />
            <TextBlock
                x:Name="newVersionTextBlock"
                HorizontalAlignment="Center"
                Foreground="LightGray" />

            <TextBlock HorizontalAlignment="Center">
                <Hyperlink x:Name="startUpdateHyperLink" Click="startUpdateHyperLink_Click">
                    <TextBlock x:Name="startUpdateTextBlock" Text="Update App" />
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <Grid Grid.Row="2" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
        </Grid>

        <UniformGrid
            x:Name="startAppGrid"
            Grid.Row="3"
            VerticalAlignment="Bottom"
            Rows="1"
            Visibility="Hidden">
            <Button
                x:Name="startButton"
                Click="startButton_Click"
                Content="Start"
                FontSize="16" />
        </UniformGrid>
    </Grid>
</celestial.controls:AdornerDialog>
